# DynamoDB endpoint — dynalite by default.
# Leave unset to point at real AWS DynamoDB (with AWS creds from ~/.aws/credentials).
DDB_ENDPOINT=http://localhost:4567
DDB_TABLE=voltify
DDB_REGION=us-east-1

# MQTT broker endpoint
MQTT_URL=mqtt://localhost:1883

# Voting threshold in °C. Sensors within this spread are considered to agree.
WARN_THRESHOLD_C=2.0

# Resend — leave RESEND_API_KEY unset to stub emails to console.log.
# Set both to actually send email on WARN/CRITICAL.
# RESEND_API_KEY=re_...
# ALERT_TO=alerts@voltify.example
# ALERT_FROM=voltify-bot@example.com
